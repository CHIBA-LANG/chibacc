    match alt {
        IrAlt(items, action) => {
            let _ = push_line_cstr(out, level, c"IrAlt")
            let _ = push_line_cstr(out, level + 1, c"items:")
            let _ = show_ir_items(out, items, level + 2)
            if action.len > 0 { push_label_str(out, level + 1, c"action: ", action) }
            else { push_line_cstr(out, level + 1, c"action: <none>") }
        }
    }

def show_ir_alts(out: Str, alts: Vec, level: i64): i64 =
    show_ir_alts_loop(out, alts, 0, level)

