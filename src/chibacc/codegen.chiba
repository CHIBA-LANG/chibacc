                } else {
                    let _ = emit_indent(out, 1)
                    let _ = str_push_cstr(out, "else { ")
                    let _ = emit_pratt_postfix_dispatch_case_fn_name(out, rule_i, block_i + 1)
                    let _ = str_push_cstr(out, "(tokens, pos, __lhs, min_bp) }\n")
                    0
                }
                let _ = emit_line_cstr(out, 0, c"}")
                let _ = str_push(out, 10)
                emit_pratt_postfix_dispatch_case_fn(out, rule_i, postfixes, block_i + 1)
            }
        }
    }

def emit_pratt_infix_dispatch_case_fn(out: Str, rule_i: i64, infixes: Vec, block_i: i64): i64 =
