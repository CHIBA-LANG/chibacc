def parse_rule_2_infix_block_1_arm_1_item_1(tokens: Vec, pos: i64): MatchResult = parse_rule_2_bp(tokens, pos, 41)

def parse_rule_2_infix_block_1_arm_1(tokens: Vec, pos: i64, __lhs: i64): MatchResult = parse_rule_2_infix_block_1_arm_1_step_0(tokens, pos, __lhs)

def parse_rule_2_infix_block_1_arm_1_step_0(tokens: Vec, pos: i64, __lhs: i64): MatchResult =
    match parse_rule_2_infix_block_1_arm_1_item_0(tokens, pos) {
        MatchOK(__v0, pos1) => parse_rule_2_infix_block_1_arm_1_step_1(tokens, pos1, __lhs, __v0)
        MatchFail => MatchFail
    }

def parse_rule_2_infix_block_1_arm_1_step_1(tokens: Vec, pos: i64, __lhs: i64, __v0: i64): MatchResult =
    match parse_rule_2_infix_block_1_arm_1_item_1(tokens, pos) {
        MatchOK(__v1, pos1) => parse_rule_2_infix_block_1_arm_1_step_2(tokens, pos1, __lhs, __v0, __v1)
        MatchFail => MatchFail
    }

def parse_rule_2_infix_block_1_arm_1_step_2(tokens: Vec, pos: i64, __lhs: i64, __v0: i64, __v1: i64): MatchResult = {
    let __lhs_ast: AST = __lhs as AST
    let rhs: AST = __v1 as AST
    MatchOK((Expr_Sub(__lhs_ast, rhs) ) as i64, pos)
}

def parse_rule_2_infix_block_1(tokens: Vec, pos: i64, __lhs: i64): MatchResult =
    match parse_rule_2_infix_block_1_arm_0(tokens, pos, __lhs) {
        MatchOK(ast, pos1) => MatchOK(ast, pos1)
        MatchFail =>
    match parse_rule_2_infix_block_1_arm_1(tokens, pos, __lhs) {
        MatchOK(ast, pos1) => MatchOK(ast, pos1)
        MatchFail => MatchFail
    }

    }

def parse_rule_2_prefix(tokens: Vec, pos: i64): MatchResult =
    match parse_rule_2_prefix_block_0(tokens, pos) {
        MatchOK(ast, pos1) => MatchOK(ast, pos1)
        MatchFail => MatchFail
    }

def parse_rule_2_postfix(tokens: Vec, pos: i64, __lhs: i64, min_bp: i64): MatchResult =
    if min_bp <= 70 {
        match parse_rule_2_postfix_block_0(tokens, pos, __lhs) {
            MatchOK(ast, pos1) => MatchOK(ast, pos1)
            MatchFail => MatchFail
        }
    }
    else { MatchFail }

def parse_rule_2_infix(tokens: Vec, pos: i64, __lhs: i64, min_bp: i64): MatchResult =
    if min_bp <= 50 {
        match parse_rule_2_infix_block_0(tokens, pos, __lhs) {
            MatchOK(ast, pos1) => MatchOK(ast, pos1)
            MatchFail =>
    if min_bp <= 40 {
        match parse_rule_2_infix_block_1(tokens, pos, __lhs) {
            MatchOK(ast, pos1) => MatchOK(ast, pos1)
            MatchFail => MatchFail
        }
    }
    else { MatchFail }

        }
    }
    else {
    if min_bp <= 40 {
        match parse_rule_2_infix_block_1(tokens, pos, __lhs) {
            MatchOK(ast, pos1) => MatchOK(ast, pos1)
            MatchFail => MatchFail
        }
    }
    else { MatchFail }

    }

def parse_rule_2_suffix(tokens: Vec, pos: i64, min_bp: i64, __lhs: i64): MatchResult =
    match parse_rule_2_postfix(tokens, pos, __lhs, min_bp) {
        MatchOK(lhs1, pos1) =>
            parse_rule_2_suffix(tokens, pos1, min_bp, lhs1)
        MatchFail => match parse_rule_2_infix(tokens, pos, __lhs, min_bp) {
            MatchOK(lhs1, pos1) =>
                parse_rule_2_suffix(tokens, pos1, min_bp, lhs1)
            MatchFail => MatchOK(__lhs, pos)
        }
    }

def parse_rule_2_bp(tokens: Vec, pos: i64, min_bp: i64): MatchResult =
    match parse_rule_2_prefix(tokens, pos) {
        MatchOK(lhs, pos1) =>
            parse_rule_2_suffix(tokens, pos1, min_bp, lhs)
        MatchFail => MatchFail
    }

def parse_rule_2(tokens: Vec, pos: i64): MatchResult = parse_rule_2_bp(tokens, pos, 0)

def parse_source(src: Str): LabeledAST = {
    let tokens = source_token_tags(src)
    match parse_rule_2(tokens, 0) {
        MatchOK(ast, pos) => {
            if pos == vec_len(tokens) { OK(ast, token_prefix(tokens, pos)) }
            else { Err(Some(ast), token_prefix(tokens, pos)) }
        }
        MatchFail => Err(None, vec_new())
    }
}


def generated_result_has_ast(ast_opt: Option[i64]): i64 =
    match ast_opt {
        Some(_) => 1
        None => 0
    }

def generated_result_append_tokens(out: Str, tokens: Vec, i: i64): i64 =
    if i >= vec_len(tokens) { 0 }
    else {
        let _ = if i > 0 { str_push(out, 32) } else { 0 }
        let tok = vec_get(tokens, i) as Str
        let _ = str_append(out, tok)
        generated_result_append_tokens(out, tokens, i + 1)
    }

def generated_result_render(res: LabeledAST): Str = {
    let out = str_new()
    match res {
        OK(_, consumed) => {
            let _ = str_push_cstr(out, "GeneratedParser.OK\n")
            let _ = str_push_cstr(out, "ConsumedCount: ")
            let _ = str_append_i64(out, vec_len(consumed))
            let _ = str_push(out, 10)
            let _ = str_push_cstr(out, "ConsumedTokens: ")
            let _ = generated_result_append_tokens(out, consumed, 0)
            let _ = str_push(out, 10)
            out
        }
        Err(ast_opt, consumed) => {
            let _ = str_push_cstr(out, "GeneratedParser.Err\n")
            let _ = str_push_cstr(out, "HasPartialAst: ")
            let _ = str_append_i64(out, generated_result_has_ast(ast_opt))
            let _ = str_push(out, 10)
            let _ = str_push_cstr(out, "ConsumedCount: ")
            let _ = str_append_i64(out, vec_len(consumed))
            let _ = str_push(out, 10)
            let _ = str_push_cstr(out, "ConsumedTokens: ")
            let _ = generated_result_append_tokens(out, consumed, 0)
            let _ = str_push(out, 10)
            out
        }
    }
}

#[entry]
def main(argc: i64, argv: i64): i64 = {
    let src = file_read_fd_all(0)
    let out = generated_result_render(parse_source(src))
    let _ = str_write_to(out, 1)
    let _ = exit(0)
    0
}