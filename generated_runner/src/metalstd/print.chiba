namespace metalstd.print
use metalstd.mem.*
use metalstd.str.*


// ── Print utilities & test assertion framework ───────────────────────────────
//
// All formatting goes through Str.  The print layer just writes finished
// strings to stdout.

// Print a NUL-terminated C string to stdout (kept for quick one-liners)
def print_s(s: i64): i64 = write_fd(1, s, strlen(s))

// Print newline
def print_nl(): i64 = write_fd(1, "\n", 1)

// Test infrastructure moved to metalstd/test.chiba
