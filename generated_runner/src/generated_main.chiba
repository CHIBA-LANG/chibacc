def parse_rule_1_alt_0_item_0(tokens: Vec, pos: i64): MatchResult = parse_rule_2(tokens, pos)

def parse_rule_1_alt_0_item_1_many(tokens: Vec, pos: i64, acc: Vec, count: i64): MatchResult = {
    match parse_rule_0(tokens, pos) {
        MatchOK(v, pos1) => {
            if pos1 == pos { MatchOK(acc as i64, pos) }
            else {
                let _ = vec_push(acc, v)
                parse_rule_1_alt_0_item_1_many(tokens, pos1, acc, count + 1)
            }
        }
        MatchFail => MatchOK(acc as i64, pos)
    }
}

