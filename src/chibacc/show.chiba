    if i >= vec_len(blocks) { 0 }
    else {
        let blk = vec_get(blocks, i) as IrInfixBlock
        let _ = show_ir_infix_block(out, blk, level)
        show_ir_infix_blocks_loop(out, blocks, i + 1, level)
    }

def show_ir_postfix_block(out: Str, blk: IrPostfixBlock, level: i64): i64 =
    match blk {
        IrPostfixBlock(bp, arms) => {
            let _ = push_line_cstr(out, level, c"IrPostfixBlock")
            let bp_s = str_new()
            let _ = str_append_i64(bp_s, bp)
            let _ = push_label_str(out, level + 1, c"binding_power: ", bp_s)
            show_ir_alts(out, arms, level + 1)
        }
    }

def show_ir_postfix_blocks(out: Str, blocks: Vec, level: i64): i64 =
    show_ir_postfix_blocks_loop(out, blocks, 0, level)

def show_ir_postfix_blocks_loop(out: Str, blocks: Vec, i: i64, level: i64): i64 =
    if i >= vec_len(blocks) { 0 }
    else {
        let blk = vec_get(blocks, i) as IrPostfixBlock
        let _ = show_ir_postfix_block(out, blk, level)
        show_ir_postfix_blocks_loop(out, blocks, i + 1, level)
    }

def show_ir_pratt_rule(out: Str, pr: IrPrattRule, level: i64): i64 =
    match pr {
        IrPrattRule(prefixes, infixes, postfixes) => {
            let _ = push_line_cstr(out, level, c"IrPrattRule")
            let _ = push_line_cstr(out, level + 1, c"prefixes:")
            let _ = show_ir_prefix_blocks(out, prefixes, level + 2)
            let _ = push_line_cstr(out, level + 1, c"infixes:")
            let _ = show_ir_infix_blocks(out, infixes, level + 2)
            let _ = push_line_cstr(out, level + 1, c"postfixes:")
            show_ir_postfix_blocks(out, postfixes, level + 2)
        }
    }

def show_ir_rule_body(out: Str, body: IrRuleBody, level: i64): i64 =
    match body {
        IrBodyAlts(alts) => {
            let _ = push_line_cstr(out, level, c"IrBodyAlts")
            show_ir_alts(out, alts, level + 1)
        }
        IrBodyPratt(pr) => show_ir_pratt_rule(out, pr, level)
    }

def show_ir_rule(out: Str, rule: IrRule, level: i64): i64 = {
    let _ = push_line_cstr(out, level, c"IrRule")
    let _ = push_label_str(out, level + 1, c"name: ", ir_rule_name(rule))
    let synth_s = if ir_rule_is_synth(rule) != 0 { mk_str("yes", 3) } else { mk_str("no", 2) }
    let _ = push_label_str(out, level + 1, c"synthetic: ", synth_s)
    let _ = push_line_cstr(out, level + 1, c"body:")
    show_ir_rule_body(out, ir_rule_body(rule), level + 2)
}

def show_ir_rules(out: Str, rules: Vec, level: i64): i64 =
    show_ir_rules_loop(out, rules, 0, level)

def show_ir_rules_loop(out: Str, rules: Vec, i: i64, level: i64): i64 =
    if i >= vec_len(rules) { 0 }
    else {
        let rule = vec_get(rules, i) as IrRule
        let _ = show_ir_rule(out, rule, level)
        show_ir_rules_loop(out, rules, i + 1, level)
    }

def show_grammar_ir(ir: GrammarIr): Str = {
    let out = str_new()
    let _ = push_line_cstr(out, 0, c"GrammarIr")
    let _ = push_label_str(out, 1, c"start: ", ir_start_rule(ir))
    let _ = push_line_cstr(out, 1, c"rules:")
    let _ = show_ir_rules(out, ir_rules(ir), 2)
    out
}

def show_debug_ast(out: Str, ast: DebugAST, level: i64): i64 =
    match ast {
        DebugToken(name) => push_label_str(out, level, c"DebugToken: ", name)
        DebugNode(name, children, action) => {
            let _ = push_line_cstr(out, level, c"DebugNode")
            let _ = push_label_str(out, level + 1, c"rule: ", name)
            let _ = if action.len > 0 { push_label_str(out, level + 1, c"action: ", action) } else { push_line_cstr(out, level + 1, c"action: <none>") }
            let _ = push_line_cstr(out, level + 1, c"children:")
            show_debug_ast_vec(out, children, level + 2)
        }
    }

def show_debug_ast_vec(out: Str, xs: Vec, level: i64): i64 =
    show_debug_ast_vec_loop(out, xs, 0, level)

def show_debug_ast_vec_loop(out: Str, xs: Vec, i: i64, level: i64): i64 =
    if i >= vec_len(xs) { 0 }
    else {
        let node = vec_get(xs, i) as DebugAST
        let _ = show_debug_ast(out, node, level)
        show_debug_ast_vec_loop(out, xs, i + 1, level)
    }

def show_token_strs(out: Str, xs: Vec, level: i64): i64 =
    show_token_strs_loop(out, xs, 0, level)

def show_token_strs_loop(out: Str, xs: Vec, i: i64, level: i64): i64 =
    if i >= vec_len(xs) { 0 }
    else {
        let tok = vec_get(xs, i) as Str
        let _ = push_label_str(out, level, c"token: ", tok)
        show_token_strs_loop(out, xs, i + 1, level)
    }

def show_labeled_ast(ast: LabeledAST): Str = {
    let out = str_new()
    match ast {
        OK(node, consumed) => {
            let _ = push_line_cstr(out, 0, c"LabeledAST.OK")
            let _ = push_line_cstr(out, 1, c"ast:")
            let _ = show_debug_ast(out, node, 2)
            let _ = push_line_cstr(out, 1, c"consumed:")
            let _ = show_token_strs(out, consumed, 2)
            out
        }
        Err(maybe_node, consumed) => {
            let _ = push_line_cstr(out, 0, c"LabeledAST.Err")
            let _ = push_line_cstr(out, 1, c"ast:")
            let _ = match maybe_node {
                Some(node) => show_debug_ast(out, node, 2)
                None => push_line_cstr(out, 2, c"<none>")
            }
            let _ = push_line_cstr(out, 1, c"consumed:")
            let _ = show_token_strs(out, consumed, 2)
            out
        }
    }
}
