                let _ = if block_i + 1 >= vec_len(postfixes) {
                    emit_line_cstr(out, 3, c"MatchFail(fail_pos) => MatchFail(fail_pos)")
                } else {
                    let _ = emit_line_cstr(out, 3, c"MatchFail(fail_pos) => {")
