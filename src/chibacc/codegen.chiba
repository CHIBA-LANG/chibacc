}

def emit_pratt_postfix_dispatch_fn(out: Str, rule_i: i64, postfixes: Vec): i64 = {
    let _ = emit_pratt_postfix_dispatch_case_fn(out, rule_i, postfixes, 0)
    let _ = emit_indent(out, 0)
    let _ = str_push_cstr(out, "def ")
    let _ = emit_pratt_postfix_dispatch_fn_name(out, rule_i)
    let _ = str_push_cstr(out, "(tokens: Vec, pos: i64, __lhs: i64, min_bp: i64): MatchResult = ")
    let _ = emit_pratt_postfix_dispatch_case_fn_name(out, rule_i, 0)
    let _ = str_push_cstr(out, "(tokens, pos, __lhs, min_bp)\n")
    0
}

def emit_pratt_infix_dispatch_fn(out: Str, rule_i: i64, infixes: Vec): i64 = {
    let _ = emit_pratt_infix_dispatch_case_fn(out, rule_i, infixes, 0)
    let _ = emit_indent(out, 0)
    let _ = str_push_cstr(out, "def ")
    let _ = emit_pratt_infix_dispatch_fn_name(out, rule_i)
    let _ = str_push_cstr(out, "(tokens: Vec, pos: i64, __lhs: i64, min_bp: i64): MatchResult = ")
    let _ = emit_pratt_infix_dispatch_case_fn_name(out, rule_i, 0)
    let _ = str_push_cstr(out, "(tokens, pos, __lhs, min_bp)\n")
    0
}

def emit_pratt_suffix_fn(out: Str, rule_i: i64): i64 = {
    let _ = emit_indent(out, 0)
    let _ = str_push_cstr(out, "def ")
    let _ = emit_pratt_suffix_fn_name(out, rule_i)
    let _ = str_push_cstr(out, "(tokens: Vec, pos: i64, min_bp: i64, __lhs: i64): MatchResult =\n")
    let _ = emit_indent(out, 1)
    let _ = str_push_cstr(out, "match ")
    let _ = emit_pratt_postfix_dispatch_fn_name(out, rule_i)
    let _ = str_push_cstr(out, "(tokens, pos, __lhs, min_bp) {\n")
    let _ = emit_line_cstr(out, 2, c"MatchOK(lhs1, pos1, recovered1) => match")
    let _ = emit_indent(out, 3)
    let _ = emit_pratt_suffix_fn_name(out, rule_i)
    let _ = str_push_cstr(out, "(tokens, pos1, min_bp, lhs1) {\n")
    let _ = emit_line_cstr(out, 4, c"MatchOK(lhs2, pos2, recovered2) => MatchOK(lhs2, pos2, recover_or(recovered1, recovered2))")
    let _ = emit_line_cstr(out, 4, c"MatchFail(fail_pos) => MatchFail(fail_pos)")
    let _ = emit_line_cstr(out, 3, c"}")
    let _ = emit_indent(out, 2)
    let _ = str_push_cstr(out, "MatchFail(fail_pos0) => match ")
    let _ = emit_pratt_infix_dispatch_fn_name(out, rule_i)
    let _ = str_push_cstr(out, "(tokens, pos, __lhs, min_bp) {\n")
    let _ = emit_line_cstr(out, 3, c"MatchOK(lhs1, pos1, recovered1) => match")
    let _ = emit_indent(out, 4)
    let _ = emit_pratt_suffix_fn_name(out, rule_i)
    let _ = str_push_cstr(out, "(tokens, pos1, min_bp, lhs1) {\n")
    let _ = emit_line_cstr(out, 5, c"MatchOK(lhs2, pos2, recovered2) => MatchOK(lhs2, pos2, recover_or(recovered1, recovered2))")
    let _ = emit_line_cstr(out, 5, c"MatchFail(fail_pos) => MatchFail(fail_pos)")
    let _ = emit_line_cstr(out, 4, c"}")
    let _ = emit_line_cstr(out, 3, c"MatchFail(fail_pos) => if fail_pos > pos { MatchFail(fail_pos) } else { MatchOK(__lhs, pos, 0) }")
    let _ = emit_line_cstr(out, 2, c"}")
    let _ = emit_line_cstr(out, 1, c"}")
    let _ = str_push(out, 10)
    0
}

def emit_pratt_rule_fns(out: Str, rules: Vec, rule_i: i64, rule_name: Str, pr: IrPrattRule): i64 =
    match pr {
        IrPrattRule(prefixes, infixes, postfixes) => {
            let _ = emit_pratt_prefix_block_fns(out, rules, rule_i, rule_name, prefixes, 0)
            let _ = emit_pratt_postfix_block_fns(out, rules, rule_i, rule_name, postfixes, 0)
            let _ = emit_pratt_infix_block_fns(out, rules, rule_i, rule_name, infixes, 0)
            let _ = emit_pratt_prefix_dispatch_fn(out, rule_i, prefixes)
            let _ = emit_pratt_postfix_dispatch_fn(out, rule_i, postfixes)
            let _ = emit_pratt_infix_dispatch_fn(out, rule_i, infixes)
            let _ = emit_pratt_suffix_fn(out, rule_i)
            let _ = emit_indent(out, 0)
            let _ = str_push_cstr(out, "def ")
            let _ = emit_rule_bp_fn_name(out, rule_i)
            let _ = str_push_cstr(out, "(tokens: Vec, pos: i64, min_bp: i64): MatchResult =\n")
            let _ = emit_indent(out, 1)
            let _ = str_push_cstr(out, "match ")
            let _ = emit_pratt_prefix_dispatch_fn_name(out, rule_i)
            let _ = str_push_cstr(out, "(tokens, pos) {\n")
            let _ = emit_line_cstr(out, 2, c"MatchOK(lhs, pos1, recovered1) => match")
            let _ = emit_indent(out, 3)
            let _ = emit_pratt_suffix_fn_name(out, rule_i)
            let _ = str_push_cstr(out, "(tokens, pos1, min_bp, lhs) {\n")
            let _ = emit_line_cstr(out, 4, c"MatchOK(ast, pos2, recovered2) => MatchOK(ast, pos2, recover_or(recovered1, recovered2))")
            let _ = emit_line_cstr(out, 4, c"MatchFail(fail_pos) => MatchFail(fail_pos)")
            let _ = emit_line_cstr(out, 3, c"}")
            let _ = emit_line_cstr(out, 2, c"MatchFail(fail_pos) => MatchFail(fail_pos)")
            let _ = emit_line_cstr(out, 1, c"}")
            let _ = str_push(out, 10)
            let _ = emit_indent(out, 0)
            let _ = str_push_cstr(out, "def ")
            let _ = emit_rule_fn_name(out, rule_i)
            let _ = str_push_cstr(out, "(tokens: Vec, pos: i64): MatchResult = ")
            let _ = emit_rule_bp_fn_name(out, rule_i)
            let _ = str_push_cstr(out, "(tokens, pos, 0)\n\n")
            0
        }
    }

def emit_done_fn(out: Str, rule_i: i64, alt_i: i64, alt: IrAlt): i64 =
    match alt {
        IrAlt(items, action) => {
            let _ = emit_indent(out, 0)
            let _ = str_push_cstr(out, "def ")
            let _ = emit_step_fn_name(out, rule_i, alt_i, vec_len(items))
            let _ = str_push_cstr(out, "(tokens: Vec, pos: i64, recovered: i64")
            let _ = emit_value_params(out, vec_len(items), 0)
            let _ = str_push_cstr(out, "): MatchResult = {\n")
            let _ = emit_label_bindings(out, items, 0)
            let _ = emit_indent(out, 1)
            let _ = str_push_cstr(out, "MatchOK((")
            let _ = str_append(out, action)
            let _ = str_push_cstr(out, ") as i64, pos, recovered)\n")
            let _ = emit_line_cstr(out, 0, c"}")
            let _ = str_push(out, 10)
            0
        }
    }

def emit_step_fn(out: Str, rules: Vec, rule_i: i64, alt_i: i64, alt: IrAlt, step_i: i64): i64 =
    match alt {
        IrAlt(items, _) => {
            if step_i >= vec_len(items) { emit_done_fn(out, rule_i, alt_i, alt) }
            else {
                let item = vec_get(items, step_i) as IrItem
                match item {
                    IrItem(_, IrAtomPredicate(raw), IrQOne) => {
                        let _ = emit_indent(out, 0)
                        let _ = str_push_cstr(out, "def ")
                        let _ = emit_step_fn_name(out, rule_i, alt_i, step_i)
                        let _ = str_push_cstr(out, "(tokens: Vec, pos: i64, recovered: i64")
                        let _ = emit_value_params(out, step_i, 0)
                        let _ = str_push_cstr(out, "): MatchResult = {\n")
                        let _ = emit_label_bindings_prefix(out, items, 0, step_i)
                        let _ = emit_indent(out, 1)
                        let _ = str_push_cstr(out, "if ")
                        let _ = emit_predicate_expr(out, raw)
                        let _ = str_push_cstr(out, " != 0 { ")
                        let _ = emit_step_fn_name(out, rule_i, alt_i, step_i + 1)
                        let _ = str_push_cstr(out, "(tokens, pos, recovered")
                        let _ = emit_value_args(out, step_i, 0)
                        let _ = str_push_cstr(out, ", 1) } else { MatchFail(pos) }\n")
                        let _ = emit_line_cstr(out, 0, c"}")
                        let _ = str_push(out, 10)
                        emit_step_fn(out, rules, rule_i, alt_i, alt, step_i + 1)
                    }
                    _ => {
                        let sync_name = if item_is_required_rule_ref(item) != 0 { find_sync_token_name(items, step_i + 1) } else { str_empty() }
                        let _ = emit_indent(out, 0)
                        let _ = str_push_cstr(out, "def ")
                        let _ = emit_step_fn_name(out, rule_i, alt_i, step_i)
                        let _ = str_push_cstr(out, "(tokens: Vec, pos: i64, recovered: i64")
                        let _ = emit_value_params(out, step_i, 0)
                        let _ = str_push_cstr(out, "): MatchResult =\n")
                        let _ = emit_indent(out, 1)
                        let _ = str_push_cstr(out, "match ")
                        let _ = emit_item_fn_name(out, rule_i, alt_i, step_i)
                        let _ = str_push_cstr(out, "(tokens, pos) {\n")
                        let _ = emit_indent(out, 2)
                        let _ = str_push_cstr(out, "MatchOK(__v")
                        let _ = emit_i64(out, step_i)
                        let _ = str_push_cstr(out, ", pos1, recovered1) => ")
                        let _ = emit_step_fn_name(out, rule_i, alt_i, step_i + 1)
                        let _ = str_push_cstr(out, "(tokens, pos1, recover_or(recovered, recovered1)")
                        let _ = emit_value_args(out, step_i, 0)
                        let _ = str_push_cstr(out, ", __v")
                        let _ = emit_i64(out, step_i)
                        let _ = str_push_cstr(out, ")\n")
                        let _ = if sync_name.len > 0 {
                            let _ = emit_line_cstr(out, 2, c"MatchFail(fail_pos) => {")
                            let _ = emit_indent(out, 3)
                            let _ = str_push_cstr(out, "let recover_pos = find_token_position(tokens, fail_pos, ")
                            let _ = emit_str_expr(out, sync_name)
                            let _ = str_push_cstr(out, ")\n")
                            let _ = emit_line_cstr(out, 3, c"if recover_pos >= 0 {")
                            let _ = emit_indent(out, 4)
                            let _ = str_push_cstr(out, "match ")
                            let _ = emit_step_fn_name(out, rule_i, alt_i, step_i + 1)
                            let _ = str_push_cstr(out, "(tokens, recover_pos, recover_or(recovered, 1)")
                            let _ = emit_value_args(out, step_i, 0)
                            let _ = str_push_cstr(out, ", 0")
                            let _ = str_push_cstr(out, ") {\n")
                            let _ = emit_line_cstr(out, 5, c"MatchOK(ast, pos2, recovered2) => MatchOK(ast, pos2, recovered2)")
                            let _ = emit_line_cstr(out, 5, c"MatchFail(fail_pos1) => MatchFail(fail_pos1)")
                            let _ = emit_line_cstr(out, 4, c"}")
                            let _ = emit_line_cstr(out, 3, c"}")
                            let _ = emit_line_cstr(out, 3, c"else { MatchFail(fail_pos) }")
                            let _ = emit_line_cstr(out, 2, c"}")
                            0
                        } else {
                            emit_line_cstr(out, 2, c"MatchFail(fail_pos) => MatchFail(fail_pos)")
                        }
                        let _ = emit_line_cstr(out, 1, c"}")
                        let _ = str_push(out, 10)
                        emit_step_fn(out, rules, rule_i, alt_i, alt, step_i + 1)
                    }
                }
            }
        }
    }

def emit_optional_item_fn(out: Str, rules: Vec, rule_i: i64, alt_i: i64, item_i: i64, atom: IrAtom): i64 = {
    let _ = emit_indent(out, 0)
    let _ = str_push_cstr(out, "def ")
    let _ = emit_item_fn_name(out, rule_i, alt_i, item_i)
    let _ = str_push_cstr(out, "(tokens: Vec, pos: i64): MatchResult =\n")
    let _ = emit_indent(out, 1)
    let _ = str_push_cstr(out, "match ")
    let _ = emit_atom_parse_expr(out, rules, atom)
    let _ = str_push_cstr(out, " {\n")
    let _ = emit_line_cstr(out, 2, c"MatchOK(v, pos1) => {")
    let _ = emit_line_cstr(out, 3, c"let some_v: Option[i64] = Some(v)")
    let _ = emit_line_cstr(out, 3, c"MatchOK(some_v as i64, pos1, recovered)")
    let _ = emit_line_cstr(out, 2, c"}")
    let _ = emit_line_cstr(out, 2, c"MatchFail(fail_pos) => {")
    let _ = emit_line_cstr(out, 3, c"if fail_pos > pos { MatchFail(fail_pos) }")
    let _ = emit_line_cstr(out, 3, c"else {")
    let _ = emit_line_cstr(out, 4, c"let none_v: Option[i64] = None")
    let _ = emit_line_cstr(out, 4, c"MatchOK(none_v as i64, pos, 0)")
    let _ = emit_line_cstr(out, 3, c"}")
    let _ = emit_line_cstr(out, 2, c"}")
    let _ = emit_line_cstr(out, 1, c"}")
    let _ = str_push(out, 10)
    0
}

def emit_many_helper_fn(out: Str, rules: Vec, rule_i: i64, alt_i: i64, item_i: i64, atom: IrAtom, min_count: i64, max_count: i64): i64 = {
    let _ = emit_indent(out, 0)
    let _ = str_push_cstr(out, "def ")
    let _ = emit_many_fn_name(out, rule_i, alt_i, item_i)
    let _ = str_push_cstr(out, "(tokens: Vec, pos: i64, acc: Vec, count: i64, recovered: i64): MatchResult = {\n")
    let _ = if max_count >= 0 {
        let _ = emit_indent(out, 1)
        let _ = str_push_cstr(out, "if count >= ")
        let _ = emit_i64(out, max_count)
        let _ = str_push_cstr(out, " { MatchOK(acc as i64, pos, recovered) }\n")
        let _ = emit_indent(out, 1)
        let _ = str_push_cstr(out, "else {\n")
        let _ = emit_indent(out, 2)
        let _ = str_push_cstr(out, "match ")
        let _ = emit_atom_parse_expr(out, rules, atom)
        let _ = str_push_cstr(out, " {\n")
        let _ = emit_line_cstr(out, 3, c"MatchOK(v, pos1, recovered1) => {")
        let _ = emit_line_cstr(out, 4, c"if pos1 == pos { MatchOK(acc as i64, pos, recover_or(recovered, recovered1)) }")
        let _ = emit_line_cstr(out, 4, c"else {")
        let _ = emit_line_cstr(out, 5, c"let _ = vec_push(acc, v)")
        let _ = emit_indent(out, 5)
        let _ = emit_many_fn_name(out, rule_i, alt_i, item_i)
        let _ = str_push_cstr(out, "(tokens, pos1, acc, count + 1, recover_or(recovered, recovered1))\n")
        let _ = emit_line_cstr(out, 4, c"}")
        let _ = emit_line_cstr(out, 3, c"}")
        let _ = if min_count <= 0 {
                    let _ = emit_line_cstr(out, 3, c"MatchFail(fail_pos) => if fail_pos > pos { MatchFail(fail_pos) } else { MatchOK(acc as i64, pos, recovered) }")
                    0
                }
                else {
                    let _ = emit_indent(out, 3)
                    let _ = str_push_cstr(out, "MatchFail(fail_pos) => if fail_pos > pos { MatchFail(fail_pos) } else if count >= ")
                    let _ = emit_i64(out, min_count)
                    let _ = str_push_cstr(out, " { MatchOK(acc as i64, pos, recovered) } else { MatchFail(pos) }\n")
                    0
                }
        let _ = emit_line_cstr(out, 2, c"}")
        let _ = emit_line_cstr(out, 1, c"}")
        0
    } else {
        let _ = emit_indent(out, 1)
        let _ = str_push_cstr(out, "match ")
        let _ = emit_atom_parse_expr(out, rules, atom)
        let _ = str_push_cstr(out, " {\n")
        let _ = emit_line_cstr(out, 2, c"MatchOK(v, pos1, recovered1) => {")
        let _ = emit_line_cstr(out, 3, c"if pos1 == pos { MatchOK(acc as i64, pos, recover_or(recovered, recovered1)) }")
        let _ = emit_line_cstr(out, 3, c"else {")
        let _ = emit_line_cstr(out, 4, c"let _ = vec_push(acc, v)")
        let _ = emit_indent(out, 4)
        let _ = emit_many_fn_name(out, rule_i, alt_i, item_i)
        let _ = str_push_cstr(out, "(tokens, pos1, acc, count + 1, recover_or(recovered, recovered1))\n")
        let _ = emit_line_cstr(out, 3, c"}")
        let _ = emit_line_cstr(out, 2, c"}")
        let _ = if min_count <= 0 {
                    let _ = emit_line_cstr(out, 2, c"MatchFail(fail_pos) => if fail_pos > pos { MatchFail(fail_pos) } else { MatchOK(acc as i64, pos, recovered) }")
                    0
                }
                else {
                    let _ = emit_indent(out, 2)
                    let _ = str_push_cstr(out, "MatchFail(fail_pos) => if fail_pos > pos { MatchFail(fail_pos) } else if count >= ")
                    let _ = emit_i64(out, min_count)
                    let _ = str_push_cstr(out, " { MatchOK(acc as i64, pos, recovered) } else { MatchFail(pos) }\n")
                    0
                }
        let _ = emit_line_cstr(out, 1, c"}")
        0
    }
    let _ = emit_line_cstr(out, 0, c"}")
    let _ = str_push(out, 10)
    0
}

def emit_repeat_item_fn(out: Str, rules: Vec, rule_i: i64, alt_i: i64, item_i: i64, atom: IrAtom, min_count: i64, max_count: i64): i64 = {
    let _ = emit_many_helper_fn(out, rules, rule_i, alt_i, item_i, atom, min_count, max_count)
    let _ = emit_indent(out, 0)
    let _ = str_push_cstr(out, "def ")
    let _ = emit_item_fn_name(out, rule_i, alt_i, item_i)
    let _ = str_push_cstr(out, "(tokens: Vec, pos: i64): MatchResult = ")
    let _ = emit_many_fn_name(out, rule_i, alt_i, item_i)
    let _ = str_push_cstr(out, "(tokens, pos, vec_new(), 0, 0)\n\n")
    0
}

def emit_one_item_fn(out: Str, rules: Vec, rule_i: i64, alt_i: i64, item_i: i64, atom: IrAtom): i64 = {
    let _ = emit_indent(out, 0)
    let _ = str_push_cstr(out, "def ")
    let _ = emit_item_fn_name(out, rule_i, alt_i, item_i)
    let _ = str_push_cstr(out, "(tokens: Vec, pos: i64): MatchResult = ")
    let _ = emit_atom_parse_expr(out, rules, atom)
    let _ = str_push_cstr(out, "\n\n")
    0
}

def emit_item_fn(out: Str, rules: Vec, rule_i: i64, alt_i: i64, item_i: i64, item: IrItem): i64 =
    match item {
        IrItem(_, atom, q) => {
            match q {
                IrQOne => emit_one_item_fn(out, rules, rule_i, alt_i, item_i, atom)
                IrQOptional => emit_optional_item_fn(out, rules, rule_i, alt_i, item_i, atom)
                IrQZeroOrMore => emit_repeat_item_fn(out, rules, rule_i, alt_i, item_i, atom, 0, 0 - 1)
                IrQOneOrMore => emit_repeat_item_fn(out, rules, rule_i, alt_i, item_i, atom, 1, 0 - 1)
                IrQRange(lo, hi) => emit_repeat_item_fn(out, rules, rule_i, alt_i, item_i, atom, lo, hi)
            }
        }
    }

def emit_item_fns(out: Str, rules: Vec, rule_i: i64, alt_i: i64, items: Vec, i: i64): i64 =
    if i >= vec_len(items) { 0 }
    else {
        let item = vec_get(items, i) as IrItem
        let _ = emit_item_fn(out, rules, rule_i, alt_i, i, item)
        emit_item_fns(out, rules, rule_i, alt_i, items, i + 1)
    }

def emit_alt_fn(out: Str, rules: Vec, rule_i: i64, alt_i: i64, alt: IrAlt): i64 =
    match alt {
        IrAlt(items, _) => {
            let _ = emit_item_fns(out, rules, rule_i, alt_i, items, 0)
            let _ = emit_indent(out, 0)
            let _ = str_push_cstr(out, "def ")
            let _ = emit_alt_fn_name(out, rule_i, alt_i)
            let _ = str_push_cstr(out, "(tokens: Vec, pos: i64): MatchResult = ")
            let _ = emit_step_fn_name(out, rule_i, alt_i, 0)
            let _ = str_push_cstr(out, "(tokens, pos, 0)\n\n")
            emit_step_fn(out, rules, rule_i, alt_i, alt, 0)
        }
    }

def emit_alt_fns(out: Str, rules: Vec, rule_i: i64, alts: Vec, alt_i: i64): i64 =
    if alt_i >= vec_len(alts) { 0 }
    else {
        let alt = vec_get(alts, alt_i) as IrAlt
        let _ = emit_alt_fn(out, rules, rule_i, alt_i, alt)
        emit_alt_fns(out, rules, rule_i, alts, alt_i + 1)
    }

def emit_rule_alt_dispatch_fn(out: Str, rule_i: i64, alts: Vec, alt_i: i64): i64 =
    if alt_i >= vec_len(alts) { 0 }
    else {
        let _ = emit_indent(out, 0)
        let _ = str_push_cstr(out, "def ")
        let _ = emit_rule_dispatch_fn_name(out, rule_i, alt_i)
        let _ = str_push_cstr(out, "(tokens: Vec, pos: i64): MatchResult =\n")
        let _ = emit_indent(out, 1)
        let _ = str_push_cstr(out, "match ")
        let _ = emit_alt_fn_name(out, rule_i, alt_i)
        let _ = str_push_cstr(out, "(tokens, pos) {\n")
        let _ = emit_line_cstr(out, 2, c"MatchOK(ast, pos1, recovered) => MatchOK(ast, pos1, recovered)")
        let _ = if alt_i + 1 >= vec_len(alts) {
            emit_line_cstr(out, 2, c"MatchFail(fail_pos) => MatchFail(fail_pos)")
        } else {
            let _ = emit_line_cstr(out, 2, c"MatchFail(fail_pos) => {")
            let _ = emit_line_cstr(out, 3, c"if fail_pos > pos { MatchFail(fail_pos) }")
            let _ = emit_indent(out, 3)
            let _ = str_push_cstr(out, "else { ")
            let _ = emit_rule_dispatch_fn_name(out, rule_i, alt_i + 1)
            let _ = str_push_cstr(out, "(tokens, pos) }\n")
            emit_line_cstr(out, 2, c"}")
        }
        let _ = emit_line_cstr(out, 1, c"}")
        let _ = str_push(out, 10)
        emit_rule_alt_dispatch_fn(out, rule_i, alts, alt_i + 1)
    }

def emit_rule_body_fn(out: Str, rules: Vec, rule_i: i64, rule: IrRule): i64 =
    match ir_rule_body(rule) {
        IrBodyAlts(alts) => {
            let _ = emit_alt_fns(out, rules, rule_i, alts, 0)
            let _ = emit_rule_alt_dispatch_fn(out, rule_i, alts, 0)
            let _ = emit_indent(out, 0)
            let _ = str_push_cstr(out, "def ")
            let _ = emit_rule_fn_name(out, rule_i)
            let _ = str_push_cstr(out, "(tokens: Vec, pos: i64): MatchResult = ")
            let _ = emit_rule_dispatch_fn_name(out, rule_i, 0)
            let _ = str_push_cstr(out, "(tokens, pos)\n")
            0
        }
        IrBodyPratt(pr) => emit_pratt_rule_fns(out, rules, rule_i, ir_rule_name(rule), pr)
    }

def emit_rule_fns(out: Str, rules: Vec, rule_i: i64): i64 =
    if rule_i >= vec_len(rules) { 0 }
    else {
        let rule = vec_get(rules, rule_i) as IrRule
        let _ = emit_rule_body_fn(out, rules, rule_i, rule)
        emit_rule_fns(out, rules, rule_i + 1)
    }

def emit_support_prelude(out: Str, file: FileAst): i64 = {
    if file_header(file).len > 0 { emit_raw_block(out, file_header(file)) }
    else { emit_line_cstr(out, 0, c"namespace generated.parser") }
}

def emit_support_imports(out: Str): i64 = {
    let _ = emit_line_cstr(out, 0, c"use metalstd.mem.*")
    let _ = emit_line_cstr(out, 0, c"use metalstd.str.*")
    let _ = emit_line_cstr(out, 0, c"use metalstd.vec.*")
    let _ = emit_line_cstr(out, 0, c"use metalstd.option.*")
    let _ = str_push(out, 10)
    0
}

def emit_support_types(out: Str): i64 = {
    let _ = emit_line_cstr(out, 0, c"data MatchResult {")
    let _ = emit_line_cstr(out, 1, c"MatchOK(i64, i64, i64),")
    let _ = emit_line_cstr(out, 1, c"MatchFail(i64)")
    let _ = emit_line_cstr(out, 0, c"}")
    let _ = str_push(out, 10)
    let _ = emit_line_cstr(out, 0, c"data LabeledAST {")
    let _ = emit_line_cstr(out, 1, c"OK(i64, Vec),")
    let _ = emit_line_cstr(out, 1, c"Err(Option[i64], Vec)")
    let _ = emit_line_cstr(out, 0, c"}")
    let _ = str_push(out, 10)
    0
}

def emit_support_helpers(out: Str): i64 = {
    let _ = emit_line_cstr(out, 0, c"def is_space_byte(b: i64): i64 =")
    let _ = emit_line_cstr(out, 1, c"if b == 32 { 1 }")
    let _ = emit_line_cstr(out, 1, c"else if b == 10 { 1 }")
    let _ = emit_line_cstr(out, 1, c"else if b == 9 { 1 }")
    let _ = emit_line_cstr(out, 1, c"else if b == 13 { 1 }")
    let _ = emit_line_cstr(out, 1, c"else { 0 }")
    let _ = str_push(out, 10)
    let _ = emit_line_cstr(out, 0, c"def source_token_tags(src: Str): Vec =")
    let _ = emit_line_cstr(out, 1, c"source_token_tags_loop(src, 0, 0 - 1, vec_new())")
    let _ = str_push(out, 10)
    let _ = emit_line_cstr(out, 0, c"def source_token_tags_loop(src: Str, i: i64, start: i64, out: Vec): Vec =")
    let _ = emit_line_cstr(out, 1, c"if i >= src.len {")
    let _ = emit_line_cstr(out, 2, c"let _ = if start >= 0 { vec_push(out, mk_str(src.ptr + start, i - start) as i64) } else { 0 }")
    let _ = emit_line_cstr(out, 2, c"out")
    let _ = emit_line_cstr(out, 1, c"}")
    let _ = emit_line_cstr(out, 1, c"else {")
    let _ = emit_line_cstr(out, 2, c"let b = load8(src.ptr, i)")
    let _ = emit_line_cstr(out, 2, c"if is_space_byte(b) != 0 {")
    let _ = emit_line_cstr(out, 3, c"let _ = if start >= 0 { vec_push(out, mk_str(src.ptr + start, i - start) as i64) } else { 0 }")
    let _ = emit_line_cstr(out, 3, c"source_token_tags_loop(src, i + 1, 0 - 1, out)")
    let _ = emit_line_cstr(out, 2, c"}")
    let _ = emit_line_cstr(out, 2, c"else {")
    let _ = emit_line_cstr(out, 3, c"let start1 = if start >= 0 { start } else { i }")
    let _ = emit_line_cstr(out, 3, c"source_token_tags_loop(src, i + 1, start1, out)")
    let _ = emit_line_cstr(out, 2, c"}")
    let _ = emit_line_cstr(out, 1, c"}")
    let _ = str_push(out, 10)
    let _ = emit_line_cstr(out, 0, c"def token_prefix(tokens: Vec, n: i64): Vec =")
    let _ = emit_line_cstr(out, 1, c"token_prefix_loop(tokens, 0, n, vec_new())")
    let _ = str_push(out, 10)
    let _ = emit_line_cstr(out, 0, c"def token_prefix_loop(tokens: Vec, i: i64, n: i64, out: Vec): Vec =")
    let _ = emit_line_cstr(out, 1, c"if i >= n || i >= vec_len(tokens) { out }")
    let _ = emit_line_cstr(out, 1, c"else {")
    let _ = emit_line_cstr(out, 2, c"let _ = vec_push(out, vec_get(tokens, i))")
    let _ = emit_line_cstr(out, 2, c"token_prefix_loop(tokens, i + 1, n, out)")
    let _ = emit_line_cstr(out, 1, c"}")
    let _ = str_push(out, 10)
    let _ = emit_line_cstr(out, 0, c"def recover_or(a: i64, b: i64): i64 =")
    let _ = emit_line_cstr(out, 1, c"if a != 0 { 1 }")
    let _ = emit_line_cstr(out, 1, c"else if b != 0 { 1 }")
    let _ = emit_line_cstr(out, 1, c"else { 0 }")
    let _ = str_push(out, 10)
    let _ = emit_line_cstr(out, 0, c"def token_matches_name(tokens: Vec, pos: i64, name: Str): i64 =")
    let _ = emit_line_cstr(out, 1, c"if streq(name, mk_str(\"Eof\", 3)) != 0 {")
    let _ = emit_line_cstr(out, 2, c"if pos == vec_len(tokens) { 1 } else { 0 }")
    let _ = emit_line_cstr(out, 1, c"}")
    let _ = emit_line_cstr(out, 1, c"else if pos < vec_len(tokens) {")
    let _ = emit_line_cstr(out, 2, c"let tok = vec_get(tokens, pos) as Str")
    let _ = emit_line_cstr(out, 2, c"if (tok as i64) != 0 && streq(tok, name) != 0 { 1 } else { 0 }")
    let _ = emit_line_cstr(out, 1, c"}")
    let _ = emit_line_cstr(out, 1, c"else { 0 }")
    let _ = str_push(out, 10)
    let _ = emit_line_cstr(out, 0, c"def find_token_position(tokens: Vec, pos: i64, name: Str): i64 =")
    let _ = emit_line_cstr(out, 1, c"if pos > vec_len(tokens) { 0 - 1 }")
    let _ = emit_line_cstr(out, 1, c"else if token_matches_name(tokens, pos, name) != 0 { pos }")
    let _ = emit_line_cstr(out, 1, c"else { find_token_position(tokens, pos + 1, name) }")
    let _ = str_push(out, 10)
    let _ = emit_line_cstr(out, 0, c"def match_token(tokens: Vec, pos: i64, want: Str): MatchResult =")
    let _ = emit_line_cstr(out, 1, c"if pos < vec_len(tokens) {")
    let _ = emit_line_cstr(out, 2, c"let tok = vec_get(tokens, pos) as Str")
    let _ = emit_line_cstr(out, 2, c"if (tok as i64) != 0 && streq(tok, want) != 0 { MatchOK(want as i64, pos + 1, 0) }")
    let _ = emit_line_cstr(out, 2, c"else { MatchFail(pos) }")
    let _ = emit_line_cstr(out, 1, c"}")
    let _ = emit_line_cstr(out, 1, c"else { MatchFail(pos) }")
    let _ = str_push(out, 10)
    let _ = emit_line_cstr(out, 0, c"def match_eof(tokens: Vec, pos: i64): MatchResult =")
    let _ = emit_line_cstr(out, 1, c"if pos == vec_len(tokens) { MatchOK(mk_str(\"Eof\", 3) as i64, pos, 0) }")
    let _ = emit_line_cstr(out, 1, c"else { MatchFail(pos) }")
    let _ = str_push(out, 10)
    0
}

def emit_start_fn(out: Str, ir: GrammarIr): i64 = {
    let start_idx = find_rule_index(ir_rules(ir), ir_start_rule(ir))
    let _ = emit_line_cstr(out, 0, c"def parse_source(src: Str): LabeledAST = {")
    let _ = emit_line_cstr(out, 1, c"let tokens = source_token_tags(src)")
    let _ = emit_indent(out, 1)
    let _ = str_push_cstr(out, "match ")
    let _ = if start_idx >= 0 { emit_rule_fn_name(out, start_idx) } else { str_push_cstr(out, "match_eof") }
    let _ = str_push_cstr(out, "(tokens, 0) {\n")
    let _ = emit_line_cstr(out, 2, c"MatchOK(ast, pos, recovered) => {")
    let _ = emit_line_cstr(out, 3, c"if pos == vec_len(tokens) && recovered == 0 { OK(ast, token_prefix(tokens, pos)) }")
    let _ = emit_line_cstr(out, 3, c"else { Err(Some(ast), token_prefix(tokens, pos)) }")
    let _ = emit_line_cstr(out, 2, c"}")
    let _ = emit_line_cstr(out, 2, c"MatchFail(fail_pos) => Err(None, token_prefix(tokens, fail_pos))")
    let _ = emit_line_cstr(out, 1, c"}")
    let _ = emit_line_cstr(out, 0, c"}")
    let _ = str_push(out, 10)
    0
}

def codegen_parser(file: FileAst, ir: GrammarIr): Str = {
    let out = str_new()
    let _ = emit_support_prelude(out, file)
    let _ = emit_support_imports(out)
    let _ = if file_footer(file).len > 0 { emit_raw_block(out, file_footer(file)) } else { 0 }
    let _ = emit_support_types(out)
    let _ = emit_support_helpers(out)
    let _ = emit_rule_fns(out, ir_rules(ir), 0)
    let _ = emit_start_fn(out, ir)
    out
}
