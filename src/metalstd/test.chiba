namespace metalstd.test
use metalstd.mem.*
use metalstd.str.*
use metalstd.print.*

// ── Test assertion framework ─────────────────────────────────────────────────
//
// Global test counters stored in heap: [passed, failed, total]

def test_init(): i64 = {
    let ctx = heap_alloc(24)
    let _ = store64(ctx, 0, 0)
    let _ = store64(ctx, 1, 0)
    let _ = store64(ctx, 2, 0)
    ctx
}

def test_pass(ctx: i64): i64 = {
    let p = load64(ctx, 0)
    let t = load64(ctx, 2)
    let _ = store64(ctx, 0, p + 1)
    store64(ctx, 2, t + 1)
}

def test_fail(ctx: i64): i64 = {
    let f = load64(ctx, 1)
    let t = load64(ctx, 2)
    let _ = store64(ctx, 1, f + 1)
    store64(ctx, 2, t + 1)
}

// Assert two i64 values are equal.  Returns 0=pass, 1=fail.
def assert_eq(ctx: i64, label: i64, actual: i64, expected: i64): i64 =
    if actual == expected {
        let _ = test_pass(ctx)
        let s = str_new()
        let _ = str_push_cstr(s, "  [PASS] ")
        let _ = str_append_cstr(s, label)
        let _ = str_push_nl(s)
        let _ = str_print(s)
        0
    } else {
        let _ = test_fail(ctx)
        let s = str_new()
        let _ = str_push_cstr(s, "  [FAIL] ")
        let _ = str_append_cstr(s, label)
        let _ = str_push_cstr(s, ": got ")
        let _ = str_push_i64(s, actual)
        let _ = str_push_cstr(s, " expected ")
        let _ = str_push_i64(s, expected)
        let _ = str_push_nl(s)
        let _ = str_print(s)
        1
    }

// Assert condition is true (non-zero)
def assert_true(ctx: i64, label: i64, cond: i64): i64 =
    if cond != 0 {
        let _ = test_pass(ctx)
        let s = str_new()
        let _ = str_push_cstr(s, "  [PASS] ")
        let _ = str_append_cstr(s, label)
        let _ = str_push_nl(s)
        let _ = str_print(s)
        0
    } else {
        let _ = test_fail(ctx)
        let s = str_new()
        let _ = str_push_cstr(s, "  [FAIL] ")
        let _ = str_append_cstr(s, label)
        let _ = str_push_cstr(s, ": expected true")
        let _ = str_push_nl(s)
        let _ = str_print(s)
        1
    }

// Print test summary.  Returns number of failures.
def test_summary(ctx: i64): i64 = {
    let passed = load64(ctx, 0)
    let failed = load64(ctx, 1)
    let total  = load64(ctx, 2)
    let s = str_new()
    let _ = str_push_nl(s)
    let _ = str_push_cstr(s, "=== ")
    let _ = str_push_i64(s, total)
    let _ = str_push_cstr(s, " tests: ")
    let _ = str_push_i64(s, passed)
    let _ = str_push_cstr(s, " passed, ")
    let _ = str_push_i64(s, failed)
    let _ = str_push_cstr(s, " failed ===")
    let _ = str_push_nl(s)
    let _ = str_print(s)
    failed
}
