def emit_pratt_prefix_dispatch_case_fn(out: Str, rule_i: i64, prefixes: Vec, block_i: i64): i64 =
    if block_i >= vec_len(prefixes) { 0 }
    else {
        let _ = emit_indent(out, 0)
        let _ = str_push_cstr(out, "def ")
