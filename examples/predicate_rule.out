def match_token(tokens: Vec, pos: i64, want: Str): MatchResult =
    if pos < vec_len(tokens) {
        let tok = vec_get(tokens, pos) as Str
        if (tok as i64) != 0 && streq(tok, want) != 0 { MatchOK(want as i64, pos + 1) }
        else { MatchFail }
    }
    else { MatchFail }

def match_eof(tokens: Vec, pos: i64): MatchResult =
    if pos == vec_len(tokens) { MatchOK(mk_str("Eof", 3) as i64, pos) }
    else { MatchFail }

